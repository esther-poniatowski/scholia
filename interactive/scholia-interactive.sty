    Use PDF viewer's layer panel to show all layers.%
  }%
}

% -----------------------------------------------------------------------------
% HIDE ALL COMMAND (placeholder)
% -----------------------------------------------------------------------------
% Toggle all hidden content back to hidden state

\newcommand{\hideAll}{%
  \PackageWarning{scholia-interactive}{%
    \string\hideAll\space is not yet implemented.
    Use PDF viewer's layer panel to hide all layers.%
  }%
}

