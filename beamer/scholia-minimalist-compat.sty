% ============================================================================
% COMPATIBILITY LAYER
%
% Provides aliases used by presentations originally built with the standalone
% "minimalist" beamer theme.  Loaded only when the `minimalistcompat` package
% option is active.
%
% These wrappers are implemented in terms of core scholia APIs
% (\scholiaicon, \titlebackground, \fadedoval, cardbox) so that source
% presentations compile with minimal edits.
%
% USAGE:
%   \usepackage[beamer,minimalistcompat]{scholia}
% ============================================================================


% ============================================================================
% SYMBOL COMMANDS
% Direct replacements for the minimalist theme's inline icon macros
% ============================================================================

\newcommand{\downarrowblack}{%
  \scholiaicon[height=\scholia@icon@height]{minimalist-down-arrow-black.pdf}\hspace{0.0ex}%
}
\newcommand{\downarrowwhite}{%
  \scholiaicon[height=\scholia@icon@height]{minimalist-down-arrow-white.pdf}\hspace{0.0ex}%
}
\newcommand{\twoheadsearrow}{%
  \scholiaicon[height=\scholia@icon@height]{minimalist-bi-arrow-horizontal.pdf}\hspace{0.0ex}%
}
\newcommand{\droparrow}{%
  \scholiaicon[height=\scholia@icon@height]{minimalist-right-curve-arrow.pdf}\hspace{0.0ex}%
}
\newcommand{\lightbulb}{%
  \scholiaicon[height=\scholia@icon@height@large]{minimalist-light-bulb.pdf}\hspace{0.01em}%
}
\newcommand{\observation}{%
  \scholiaicon[height=\scholia@icon@height]{minimalist-observation.pdf}\hspace{0.0ex}%
}
\newcommand{\paper}{%
  \scholiaicon[height=0.9em]{minimalist-paper-1.pdf}\hspace{0.0ex}%
}


% ============================================================================
% IDEABOXGRAY ENVIRONMENT
% Migration alias for the minimalist theme's ideaboxgray tcolorbox
% ============================================================================

\NewDocumentEnvironment{ideaboxgray}{O{} m}{%
  \begin{ideacard}[title={#2}, box options={#1}]%
}{%
  \end{ideacard}%
}


% ============================================================================
% TITLE BACKGROUND ALIAS
% The minimalist theme used \setTitleBackground as a no-argument command
% with a hardcoded image.  Users must replace it with \titlebackground{path}
% in their documents.  This alias is provided only as documentation.
% ============================================================================

\newcommand{\scholia@minimalist@titlebackgroundpath}{}

\newcommand{\setMinimalistTitleBackground}[1]{%
  \gdef\scholia@minimalist@titlebackgroundpath{#1}%
}

\NewDocumentCommand{\setTitleBackground}{o}{%
  \IfValueT{#1}{\setMinimalistTitleBackground{#1}}%
  \scholia@ifmacroemptyTF{\scholia@minimalist@titlebackgroundpath}{%
    \PackageWarning{scholia}{\string\setTitleBackground\space called without a configured background image; use \string\setMinimalistTitleBackground\space or \string\setTitleBackground[path]}%
  }{%
    \titlebackground{\scholia@minimalist@titlebackgroundpath}%
  }%
}


% ============================================================================
% LEGACY \fadedoval INTERFACE
% Preserve the core keyed API while accepting the original 5-argument form:
%   \fadedoval{color}{text}{horizontal-radius-cm}{vertical-radius-cm}{text-width-cm}
% ============================================================================

\RenewDocumentCommand{\fadedoval}{o m g g g g}{%
  \IfValueTF{#1}{%
    \scholia@fadedoval@render{#1}{#2}%
  }{%
    \IfValueTF{#3}{%
      \IfValueTF{#4}{%
        \IfValueTF{#5}{%
          \IfValueTF{#6}{%
            \scholia@fadedoval@render{%
              color=#2,
              horizontal radius=#4cm,
              vertical radius=#5cm,
              text width=#6cm
            }{#3}%
          }{%
            \PackageError{scholia}{Legacy \string\fadedoval\space requires five braced arguments}{Use \string\fadedoval[keys]{text} or \string\fadedoval{color}{text}{horizontal-radius-cm}{vertical-radius-cm}{text-width-cm}.}%
          }%
        }{%
          \PackageError{scholia}{Legacy \string\fadedoval\space requires five braced arguments}{Use \string\fadedoval[keys]{text} or \string\fadedoval{color}{text}{horizontal-radius-cm}{vertical-radius-cm}{text-width-cm}.}%
        }%
      }{%
        \PackageError{scholia}{Legacy \string\fadedoval\space requires five braced arguments}{Use \string\fadedoval[keys]{text} or \string\fadedoval{color}{text}{horizontal-radius-cm}{vertical-radius-cm}{text-width-cm}.}%
      }%
    }{%
      \scholia@fadedoval@render{}{#2}%
    }%
  }%
}


