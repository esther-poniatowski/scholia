% Solutions mode flag
% Controlled via:
%   1. Package option: \usepackage[solutions]{scholia}
%   2. Document preamble: \solutionstrue (after loading scholia)
%   3. Command-line: pdflatex "\def\ForceSolutions{}\input{file}"
\newif\ifsolutions

% Inherit from package option if set
\ifscholia@solutions
  \solutionstrue
\fi

% Support command-line injection
\ifdefined\ForceSolutions
  \solutionstrue
\fi

% NOTE: General-purpose commands moved to base/utilities.sty:
%   \highlight, \dotsBlank, \fillBlank, \blankLine,
%   \solutionBlank, \solutionDotsBlank

% ============================================================================
% EXERCISE ENVIRONMENTS
% PURPOSE: Define environments for different types of exercises
%
% Usage:
%   \begin{exguided}[Title] ... \end{exguided}
%   \begin{exsemiguided}[Title] ... \end{exsemiguided}
%   \begin{exauto}[Title][level] ... \end{exauto}
%   \begin{exmodel}[Title] ... \end{exmodel}
%
% The title is optional. The difficulty level (0, 1, 2 or 3) is optional.
% ============================================================================

% --- Global exercise counter ---
\newcounter{exonum}
\renewcommand{\theexonum}{\arabic{exonum}}

% --- Title and stars (internal) ---
\newcommand{\scholia@exo@title}[1]{%
  \textbf{\scholia@str@exo@label\ \theexonum}%
  \scholia@ifblankTF{#1}{}{\ -- \textit{#1}}%
}

\newcommand{\scholia@exo@starsymbol}{\ensuremath{\bigstar}}

\newcommand{\scholia@exo@difficultystars}[1]{%
  \begingroup
  \def\onestar{\scholia@exo@starsymbol}%
  \ifnum#1=1 \onestar\fi
  \ifnum#1=2 \onestar\onestar\fi
  \ifnum#1=3 \onestar\onestar\onestar\fi
  \endgroup
}

\definecolor{exotitle}{RGB}{30,30,30}

% --- Exercise type icon filenames (internal) ---
\newcommand{\scholia@exo@icon@guide}{map-pin-plus.pdf}
\newcommand{\scholia@exo@icon@semiguide}{map-pin-check.pdf}
\newcommand{\scholia@exo@icon@autonome}{map-pin-pen.pdf}
\newcommand{\scholia@exo@icon@modelisation}{puzzle.pdf}

\newcommand{\scholia@exo@settitlewidth}{%
  \ifscholia@noicons
    \setlength{\scholia@exo@titlewidth}{\linewidth}%
  \else
    \setlength{\scholia@exo@titlewidth}{\dimexpr\linewidth-2.5em\relax}%
  \fi
}

\newcommand{\scholia@exo@titleprefix}[1]{%
  \ifscholia@noicons\else
    \scholia@icon@render{#1}\hspace{\scholia@icon@spacing}%
  \fi
}

% --- tcolorbox styles for exercises ---
\tcbset{
  exo_base/.style={
    enhanced,
    breakable,
    colback=white,
    colframe=black!10,
    boxrule=0.4pt,
    arc=3pt,
    left=7pt,right=7pt,top=6pt,bottom=6pt,
    before skip=8pt, after skip=8pt,
    coltitle=exotitle,
    fonttitle=\bfseries,
    % title merged with background (no separate band)
    attach boxed title to top left={
      xshift=7pt,yshift=-4pt,
    },
    boxed title style={
      colback=white,
      colframe=white,
      boxrule=0pt,
      left=0pt,right=0pt,top=0pt,bottom=0pt,
    },
  },
  exo_guide/.style={
    exo_base,
    colback=gray!3,
    colframe=gray!40,
  },
  exo_semiguide/.style={
    exo_base,
    colback=gray!3,
    colframe=gray!40,
  },
  exo_autonome/.style={
    exo_base,
    colback=gray!3,
    colframe=gray!40,
  },
  exo_modelisation/.style={
    exo_base,
    colback=gray!3,
    colframe=gray!40,
  },
}


% --- Exercise environments ---

% Title width for wrapping long titles (accounts for icon + margins)
\newlength{\scholia@exo@titlewidth}

\newcommand{\scholia@exo@titre@guide}[1]{%
  \scholia@exo@settitlewidth%
  \scholia@exo@titleprefix{\scholia@exo@icon@guide}%
  \begin{minipage}[t]{\scholia@exo@titlewidth}%
    \raggedright\textcolor{exotitle}{\scholia@exo@title{#1}}%
  \end{minipage}%
}
\NewDocumentEnvironment{exguided}{O{}}%
{%
  \refstepcounter{exonum}%
  \setcounter{scholia@circlednum}{0}%  % reset question counter
  \def\currentexotitle{#1}%
  \begin{tcolorbox}[%
    exo_guide,
    title={\scholia@exo@titre@guide{\currentexotitle}}%
  ]%
}%
{%
  \end{tcolorbox}%
}


\newcommand{\scholia@exo@titre@semiguide}[1]{%
  \scholia@exo@settitlewidth%
  \scholia@exo@titleprefix{\scholia@exo@icon@semiguide}%
  \begin{minipage}[t]{\scholia@exo@titlewidth}%
    \raggedright\textcolor{exotitle}{\scholia@exo@title{#1}}%
  \end{minipage}%
}
\NewDocumentEnvironment{exsemiguided}{O{}}%
{%
  \refstepcounter{exonum}%
  \setcounter{scholia@circlednum}{0}%  % reset question counter
  \def\currentexotitle{#1}%
  \begin{tcolorbox}[%
    exo_semiguide,
    title={\scholia@exo@titre@semiguide{\currentexotitle}}%
  ]%
}%
{%
  \end{tcolorbox}%
}


\newcommand{\scholia@exo@titre@autonome}[2]{%
  \scholia@exo@settitlewidth%
  \scholia@exo@titleprefix{\scholia@exo@icon@autonome}%
  \begin{minipage}[t]{\scholia@exo@titlewidth}%
    \raggedright\textcolor{exotitle}{%
      \scholia@exo@title{#1}%
      \scholia@ifblankTF{#2}{}{\quad\scholia@exo@difficultystars{#2}}%
    }%
  \end{minipage}%
}

\NewDocumentEnvironment{exauto}{O{} O{}}%
{%
  \refstepcounter{exonum}%
  \setcounter{scholia@circlednum}{0}%  % reset question counter
  \def\currentexotitle{#1}%
  \def\currentexodiff{#2}%
  \begin{tcolorbox}[%
    exo_autonome,
    title={\scholia@exo@titre@autonome{\currentexotitle}{\currentexodiff}}%
  ]%
}%
{%
  \end{tcolorbox}%
}


\newcommand{\scholia@exo@titre@modelisation}[1]{%
  \scholia@exo@settitlewidth%
  \scholia@exo@titleprefix{\scholia@exo@icon@modelisation}%
  \begin{minipage}[t]{\scholia@exo@titlewidth}%
    \raggedright\textcolor{exotitle}{\scholia@exo@title{#1}\quad\scholia@exo@type@modelisation}%
  \end{minipage}%
}
\NewDocumentEnvironment{exmodel}{O{}}%
{%
  \refstepcounter{exonum}%
  \setcounter{scholia@circlednum}{0}%  % reset question counter
  \def\currentexotitle{#1}%
  \begin{tcolorbox}[%
    exo_modelisation,
    title={\scholia@exo@titre@modelisation{\currentexotitle}}%
  ]%
}%
{%
  \end{tcolorbox}%
}

% ============================================================================
% INNER STRUCTURE FOR EXERCISES
% PURPOSE: Define commands and environments for inner exercise structure
% USAGE:
% \exstep[Optional Title] ... for each step in an exercise
% \begin{hint} ... \end{hint} for hints within an exercise
% \begin{furtherreading} ... \end{furtherreading} for further reading sections
% DEPENDENCIES: none
% ============================================================================
\newcounter{exoitem}
\newcommand{\resetexsteps}{\setcounter{exoitem}{0}}

\NewDocumentCommand{\exstep}{O{}}{%
  \refstepcounter{exoitem}%
  \par\medskip\noindent\textbf{\alph{exoitem})}%
  \scholia@ifblankTF{#1}{}{\ \textit{#1}}%
  \quad
}

\newenvironment{hint}{%
  \par\smallskip\noindent\textbf{\scholia@str@exo@hint\ }\itshape
}{\par\smallskip\normalfont}

\newenvironment{furtherreading}{%
  \par\smallskip\noindent\textbf{\scholia@str@exo@further\ }\itshape
}{\par\smallskip\normalfont}


% ============================================================================
% MULTI-COLUMN ENVIRONMENT FOR EXERCISES
% PURPOSE: Define an environment to display exercises in two columns
% USAGE:
%   \begin{extwocol} ... \end{extwocol}                  % no separator (default)
%   \begin{extwocol}[separator] ... \end{extwocol}       % with dotted separator
% DEPENDENCIES: multicol, multicolrule
% ============================================================================
\newlength{\exocolsep}
\setlength{\exocolsep}{18pt}

\newcommand{\scholia@exo@setupcolumns@plain}{%
  \setlength{\columnseprule}{0pt}%
  \setlength{\columnsep}{\exocolsep}%
}

\newcommand{\scholia@exo@setupcolumns@separator}{%
  \setlength{\columnseprule}{0.6pt}%
  \SetMCRule{line-style=dots,color=gray!60}%
  \setlength{\columnsep}{\exocolsep}%
}

\NewDocumentEnvironment{extwocol}{O{}}%
{%
  \par\medskip
  \ifx&#1&%
    \scholia@exo@setupcolumns@plain
  \else
    \scholia@exo@setupcolumns@separator
  \fi
  \raggedcolumns% Disable vertical stretching to avoid blank spaces
  \begin{multicols}{2}%
}%
{%
  \end{multicols}%
  \par\medskip
}

% ============================================================================
% CORRECTION ENVIRONMENT
% PURPOSE: Environment for exercise corrections with consistent styling
% USAGE:
%   \begin{excorrection}{Title}         % automatic numbering
%   \begin{excorrection}[3]{Title}      % forces number 3
% The optional number overrides automatic numbering (useful for partial corrections)
% ============================================================================
\tcbset{
  exo_correction/.style={
    enhanced,
    breakable,
    colback=white,
    colframe=gray!40,
    boxrule=0.4pt,
    arc=3pt,
    left=7pt,right=7pt,top=6pt,bottom=6pt,
    before skip=8pt, after skip=8pt,
    coltitle=exotitle,
    fonttitle=\bfseries,
    attach boxed title to top left={
      xshift=7pt,yshift=-4pt,
    },
    boxed title style={
      colback=white,
      colframe=white,
      boxrule=0pt,
      left=0pt,right=0pt,top=0pt,bottom=0pt,
    },
  },
}

\newcommand{\scholia@exo@titre@correction}[2]{%
  \scholia@exo@settitlewidth%
  \scholia@exo@titleprefix{\scholia@exo@icon@autonome}%
  \begin{minipage}[t]{\scholia@exo@titlewidth}%
    \raggedright\textcolor{exotitle}{%
      \textbf{\scholia@str@exo@label\ #1}%
      \scholia@ifblankTF{#2}{}{\ — \textit{#2}}%
    }%
  \end{minipage}%
}

\NewDocumentEnvironment{excorrection}{O{} m}%
{%
  \scholia@ifblankTF{#1}{%
    % No manual number: increment counter
    \refstepcounter{exonum}%
    \edef\currentexonum{\theexonum}%
  }{%
    % Manual number provided: use without incrementing
    \edef\currentexonum{#1}%
  }%
  \setcounter{scholia@circlednum}{0}%
  \def\currentexotitle{#2}%
  \begin{tcolorbox}[%
    exo_correction,
    title={\scholia@exo@titre@correction{\currentexonum}{\currentexotitle}}%
  ]%
}%
{%
  \end{tcolorbox}%
}

% ============================================================================
% QUESTION HIGHLIGHT COMMAND FOR CORRECTIONS
% PURPOSE: Highlight question statement in corrections with gray background
% USAGE:
%   \qstatement{Calculate the image of 4.}
%   \qstatement{Determine the antecedent(s) of $3 - \sqrt{5}$.}
% Automatically increments question counter and displays circled number.
% ============================================================================
\definecolor{questionenoncebg}{RGB}{240,240,240}

\newcommand{\qstatement}[1]{%
  \stepcounter{scholia@circlednum}%
  \par\medskip\noindent
  \colorbox{questionenoncebg}{%
    \parbox{\dimexpr\linewidth-2\fboxsep\relax}{%
      \strut\textcircled{\thescholia@circlednum}\;#1\strut
    }%
  }%
  \par\medskip
}


\endinput
