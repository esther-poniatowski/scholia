% ============================================================================
% SEMANTIC INLINE LABELS
% PURPOSE: Typed inline boxes for categorizing and labeling content
%
% These commands create colored inline boxes that visually identify content
% categories. They use \inlineframebox from base/scholia-boxes.sty with semantic
% colors from base/scholia-colors.sty.
%
% Syntax:
%   \<type>label{text}       - Box with text
%   \<type>label*{text}      - Box with arrow prefix (for navigation)
%
% Example:
%   See the \notionlabel*{definition of continuity}.
%   Apply \methodlabel{Method M2} to solve.
%
% All labels are generated using the \scholia@label@new factory from
% base/scholia-factories.sty, ensuring consistent interface across all types.
% ============================================================================

% Generate all semantic label commands using factory
\scholia@label@new{notion}          % Cyan - theoretical content
\scholia@label@new{exercise}        % Orange - practice activities
\scholia@label@new{solution}        % Green - answers, corrections
\scholia@label@new{method}          % Blue - methods, procedures
\scholia@label@new{assessment}      % Red - formal evaluations
\scholia@label@new{autocheck}       % Purple - self-evaluation
\scholia@label@new{keypoint}        % Gold - key highlights
\scholia@label@new{research}        % Reddish-orange - exploration
\scholia@label@new{summary}         % Gray-brown - overviews
\scholia@label@new{diagnostic}      % Steel blue - student records


