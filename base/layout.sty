\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{scholia-layout}[2026/01/31 v0.1.0 Layout utilities]

% ============================================================================
% LAYOUT UTILITIES
% PURPOSE: Document structure elements - headers, blocks, column layouts
%          These create structural divisions and visual separators
% ============================================================================


% ============================================================================
% BLOCK HEADERS
% PURPOSE: Section-level visual separators with titles
% ============================================================================

% Chapter header with underline
% Usage: \chapterBlock{Chapter name}
\newcommand{\chapterBlock}[1]{%
  \vspace{0.1em}
  \noindent\textbf{\sffamily\large #1}
  \vspace{0.1em}
  \hrule
  \vspace{0.3em}
}

% Section header with colored background
% Usage: \sectionBlock[color]{Section name}
\NewDocumentCommand{\sectionBlock}{O{gray!15} m}{%
  \vspace{0.1em}
  \noindent\colorbox{#1}{\textbf{\sffamily\large #2}}
  \vspace{0.1em}
  \hrule
  \vspace{0.3em}
}


% ============================================================================
% NOTATION HELPERS
% PURPOSE: Two-column layouts for notation lists and definitions
% ============================================================================

% Two-column notation line
% Usage: \notionLine{code}{description}
\newcommand{\notionLine}[2]{%
  \noindent\makebox[1.6cm][l]{#1} #2 \\[0.3em]
}


\endinput
