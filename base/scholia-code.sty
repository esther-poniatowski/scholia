\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{\@currpath\@currname}[2026/03/20 v0.2.0 Code formatting]

\definecolor{codebackground}{RGB}{250, 250, 250}
\definecolor{keywordcolor}{RGB}{197, 134, 192}     % violet pastel
\definecolor{stringcolor}{RGB}{230, 219, 116}      % yellow pastel
\definecolor{commentcolor}{RGB}{117, 113, 94}      % gray-brown
\definecolor{functioncolor}{RGB}{102, 217, 239}    % cyan pastel
\definecolor{numbercolor}{RGB}{174, 129, 255}      % light violet
\definecolor{operatorcolor}{RGB}{249, 38, 114}     % bright pink
\definecolor{identifiercolor}{RGB}{166, 226, 46}   % lime green

% ============================================================================
% Python code style
% DEPENDENCIES: listings, xcolor
% PURPOSE: Define a consistent style for Python code listings
% USAGE: \begin{lstlisting} ... \end{lstlisting}
% ============================================================================
\lstdefinestyle{python}{
  language=Python,
  % Background and frame colors
  backgroundcolor=\color{codebackground},
  frame=single,
  rulecolor=\color{black!20},
  framesep=3mm,
  framexleftmargin=3mm,
  % Typographic styles
  basicstyle=\ttfamily\small\color{black!90},
  keywordstyle=\bfseries\color{keywordcolor},
  stringstyle=\color{stringcolor},
  commentstyle=\itshape\color{commentcolor},
  % Numbering and spacing
  numbers=left,
  numberstyle=\tiny\color{black!40},
  numbersep=8pt,
  stepnumber=1,
  % Additional classified keywords
  keywords=[2]{self,cls,super,len,range,enumerate,zip,map,filter},
  keywordstyle=[2]\color{functioncolor},
  keywords=[3]{int,str,float,bool,list,dict,tuple,set},
  keywordstyle=[3]\color{operatorcolor},
  % UTF-8 configuration
  showstringspaces=false,
  columns=fullflexible,
  keepspaces=true,
  inputencoding=utf8,
  extendedchars=true,
  literate={é}{{\'e}}1 {è}{{\`e}}1 {ê}{{\^e}}1 {ë}{{\"e}}1
    {à}{{\`a}}1 {â}{{\^a}}1 {ù}{{\`u}}1 {û}{{\^u}}1
    {ô}{{\^o}}1 {î}{{\^i}}1 {ï}{{\"i}}1 {ç}{{\c{c}}}1,
  % Line breaking
  breaklines=true,
  breakatwhitespace=true,
  postbreak=\mbox{\textcolor{red}{$\hookrightarrow$}\space},
  % Tabulations
  tabsize=4,
  showtabs=false
}

\lstset{style=python} % Set Python style as default

% ============================================================================
% Commands for inline code
% DEPENDENCIES: listings, xcolor
% PURPOSE: Define a style for inline code snippets
% USAGE: ... \code{code_here} or \code|code_here| ...
% Note: The command \code uses lstinline with the defined style
% ============================================================================

\definecolor{codebg}{RGB}{245,245,245} % very light gray

\lstdefinestyle{inlinecode}{
  basicstyle=\ttfamily\small\color{blue!60!black},
  backgroundcolor=\color{codebg},
  frame=single,
  framerule=0.5pt,
  rulecolor=\color{codebg},
  xleftmargin=0.2em,
  xrightmargin=0.2em,
  aboveskip=0pt,
  belowskip=0pt
}

\newcommand{\code}{\lstinline[style=inlinecode]} % Inline code command


\endinput
