\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{scholia-base-graphics}[2026/01/31 v0.1.0 Graphics configuration]

% Graphics search paths for package icons
% Note: \scholia@basepath is defined by scholia.sty for package-relative paths
% Users should add their own project-specific paths in their preamble
\graphicspath{%
    {\scholia@basepath/icons/pdf/}%   % Package icons in PDF format (vector)
    {\scholia@basepath/icons/png/}%   % Fallback: PNG icons (raster)
}

% ============================================================================
% ICON STYLE
% PURPOSE: Define a TikZ style for including icons in nodes
% USAGE: \node[icon={width}{filename}] {};
% ============================================================================
\tikzset{
  icon/.style 2 args={
    path picture={
      \node at (path picture bounding box.center)
        {\includegraphics[width=#1]{#2}};
    }
  }
}


\endinput
