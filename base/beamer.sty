% ============================================================================
% OBJECTIVE BOX IN HEADLINE
% PURPOSE:
%   Display the current learning objective in the beamer headline as a
%   clean, minimal banner with an icon on the left and the objective text
%   on a light gray background.
%
% VISUAL DESIGN:
%   - Left: circular container with a locate-fixed icon (objective symbol).
%   - Right: light gray rectangular background with bold objective text.
%   - No borders; only soft gray backgrounds.
%   - Objective text is bold and uses the normal text foreground colour.
%
% USAGE IN MAIN DOCUMENT:
%   1. Ensure TikZ is loaded in the global preamble (already done in packages).
%   2. Ensure the icon file exists, for example:
%        <project-root>/common/icons/pdf/locate-fixed.pdf
%   3. Adjust \ObjectiveIconPath below so that:
%        \includegraphics{<\ObjectiveIconPath>} finds the icon.
%      Example:
%        \renewcommand{\ObjectiveIconPath}{\CommonPath/icons/locate-fixed}
%   4. Before frames where an objective must appear, call:
%        \setobjective{Résoudre des systèmes par combinaisons}
%      The last set objective persists until changed.
%   5. To clear the objective (empty headline box):
%        \setobjective{}
%
% FALLBACK BEHAVIOUR:
%   - If \setobjective has never been called, \currentobjective is empty,
%     so the banner shows only the icon and a blank gray bar (no error).
% ============================================================================

% Default objective (empty)
\newcommand{\currentobjective}{}

% Icon used in the objective headline banner
% Default uses the locate-fixed icon from the package
% Override in your preamble if needed:
%   \renewcommand{\ObjectiveIconPath}{your-icon.pdf}
\newcommand{\ObjectiveIconPath}{locate-fixed.pdf}

% Setter for the current objective
\newcommand{\setobjective}[1]{\renewcommand{\currentobjective}{#1}}

\setbeamertemplate{headline}{%
  \vskip4pt
  \hspace*{-\beamer@leftmargin}%
  \begin{beamercolorbox}[%
      wd=\paperwidth,
      ht=8mm,
      dp=1mm,
      leftskip=\beamer@leftmargin,
      rightskip=\beamer@rightmargin
    ]{headline}%
    \begin{tikzpicture}[inner sep=0pt, outer sep=0pt]
      % Left: circular icon container (shifted right)
      \node[
        circle,
        fill=gray!15,
        draw=none,
        inner sep=3pt,
        anchor=west
      ] (objectiveicon) at (0,0) {%
        \includegraphics[height=1.2em]{\ObjectiveIconPath}%
      };

      % Right: light gray background with bold objective text
      \node[
        rectangle,
        fill=gray!12,
        draw=none,
        inner sep=3.5pt,
        text width=0.91\paperwidth, % extend further to the right
        anchor=west,
        font=\small\bfseries
      ] (objectivetext) at ([xshift=6pt]objectiveicon.east) {%
        \strut\currentobjective\strut%
      };
    \end{tikzpicture}
  \end{beamercolorbox}%
  \vskip4pt
}


