\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{scholia-base-beamer}[2026/01/31 v0.1.0 Beamer class configuration]

\usetheme{default}
\usefonttheme{professionalfonts}

\setbeamertemplate{navigation symbols}{} % no navigation symbols
\setbeamertemplate{footline}[frame number] % frame number in footline

% --- Global fonts ---
\setbeamerfont{title}{size=\Large,series=\bfseries}
\setbeamerfont{subtitle}{size=\large}
\setbeamerfont{frametitle}{size=\normalsize,series=\bfseries}
\setbeamerfont{normal text}{size=\small}  % default text size


% --- Global colors ---
\setbeamercolor{title}{fg=black}
\setbeamercolor{subtitle}{fg=gray}
\setbeamercolor{frametitle}{fg=black,bg=white}
\setbeamercolor{normal text}{fg=black}


% --- Itemize colors and symbols ---
\setbeamercolor{item}{fg=black}
\setbeamertemplate{itemize item}{\textcolor{black}{$\bullet$}}
\setbeamertemplate{itemize subitem}{\textcolor{black}{\footnotesize$\bullet$}}


% ============================================================================
% BANNER WITH ICON
% PURPOSE:
%   Display a clean, minimal banner with an icon on the left and text on
%   a light gray background.  Used for the headline (objective mode) and
%   for the frametitle (frametitle mode).
%
% VISUAL DESIGN:
%   - Left: circular container with an icon (loader by default).
%   - Right: light gray rectangular background with bold text.
%   - No borders; only soft gray backgrounds.
%
% TWO MODES (mutually exclusive):
%   1. Objective mode (default) — the banner sits in the headline and
%      displays a persistent objective text set via \setobjective{...}.
%      The standard beamer frametitle is used for frame titles.
%   2. Frametitle mode — the banner moves to the frametitle template
%      and displays \insertframetitle.  The headline is emptied.
%      Activate with \headlineshowsframetitle in the preamble.
%
% ICON:
%   The banner icon defaults to loader.pdf (shipped in icons/pdf/).
%   Override in the preamble if needed:
%     \renewcommand{\ObjectiveIconPath}{your-icon.pdf}
%
% OBJECTIVE MODE USAGE:
%   1. Before frames where an objective must appear, call:
%        \setobjective{Solve systems by linear combinations}
%      The last set objective persists until changed.
%   2. To clear the objective: \setobjective{}
% ============================================================================

% --- Mode flag ---
\newif\ifscholia@beamer@headlineframetitle
\scholia@beamer@headlineframetitlefalse

% --- Public commands ---

% Default objective (empty)
\newcommand{\currentobjective}{}

% Setter for the current objective (objective mode)
\newcommand{\setobjective}[1]{\renewcommand{\currentobjective}{#1}}

% Icon used in the banner
\newcommand{\ObjectiveIconPath}{loader.pdf}

% Switch to frametitle mode: the banner shows \insertframetitle
\newcommand{\headlineshowsframetitle}{%
  \scholia@beamer@headlineframetitletrue
  \setbeamertemplate{headline}{}%
  \setbeamertemplate{frametitle}{%
    \scholia@beamer@banner{\insertframetitle}%
  }%
}

% --- Internal banner macro ---
% \scholia@beamer@banner{<text>}
% Renders the icon + text banner.  Called inside a beamer template.
\newcommand{\scholia@beamer@banner}[1]{%
  \vskip4pt
  \hspace*{-\beamer@leftmargin}%
  \begin{beamercolorbox}[%
      wd=\paperwidth,
      ht=8mm,
      dp=1mm,
      leftskip=\beamer@leftmargin,
      rightskip=\beamer@rightmargin
    ]{headline}%
    \begin{tikzpicture}[inner sep=0pt, outer sep=0pt]
      % Left: circular icon container
      \node[
        circle,
        fill=gray!15,
        draw=none,
        inner sep=3pt,
        anchor=west
      ] (bannericon) at (0,0) {%
        \includegraphics[height=1.2em]{\ObjectiveIconPath}%
      };
      % Right: light gray background with bold text
      \node[
        rectangle,
        fill=gray!12,
        draw=none,
        inner sep=3.5pt,
        text width=0.91\paperwidth,
        anchor=west,
        font=\small\bfseries
      ] (bannertext) at ([xshift=6pt]bannericon.east) {%
        \strut#1\strut%
      };
    \end{tikzpicture}
  \end{beamercolorbox}%
  \vskip4pt
}

% --- Default: objective mode (headline shows \currentobjective) ---
\setbeamertemplate{headline}{%
  \scholia@beamer@banner{\currentobjective}%
}


\endinput
