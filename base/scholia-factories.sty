% ============================================================================
% FACTORY MACROS
% PURPOSE: Generate repetitive command/environment definitions from templates
%
% This module provides factory macros that reduce code duplication by
% generating families of related commands from simple declarations.
% ============================================================================


% ============================================================================
% EMPTY-CONTENT HELPERS
% PURPOSE: Centralize blank checks for token lists and stored macros
%
% Usage:
%   \scholia@ifblankTF{<token list>}{<empty>}{<non-empty>}
%   \scholia@ifmacroemptyTF{\mymacro}{<empty>}{<non-empty>}
% ============================================================================

\newcommand{\scholia@ifblankTF}[3]{%
  \if\relax\detokenize{#1}\relax
    #2%
  \else
    #3%
  \fi
}

\newcommand{\scholia@ifmacroemptyTF}[3]{%
  \ifdefempty{#1}{#2}{#3}%
}


% ============================================================================
% SEMANTIC LABEL FACTORY
% PURPOSE: Generate inline label commands with consistent interface
%
% Usage:
%   \scholia@label@new{typename}
%   Creates \<typename>label command that wraps \inlineframebox
%
% The generated command accepts:
%   - Starred form: adds navigation arrow
%   - Unstarred form: label only
% ============================================================================

\newcommand{\scholia@label@new}[1]{%
  \expandafter\NewDocumentCommand\csname #1label\endcsname{s m}{%
    \IfBooleanTF{##1}%
      {\inlineframebox[scholia-#1]*{##2}}%
      {\inlineframebox[scholia-#1]{##2}}%
  }%
}


% ============================================================================
% CALLOUT TYPE FACTORY
% PURPOSE: Generate callout box and mark environments from type name
%
% Usage:
%   \scholia@callout@newtype{typename}
%   Creates:
%     - \<typename>box environment (full callout with optional title and options)
%     - \<typename>mark environment (compact inline marker)
%
% Box environment signature:
%   \begin{<type>box}[title][tcolorbox options] ... \end{<type>box}
%   Both optional arguments default to empty.
%   The second optional argument accepts any tcolorbox key, including "centered".
%
% Prerequisites:
%   - Color scholia-<typename> must be defined
%   - Icon \scholia@callout@icon@<typename> must be defined
%   - Style "callout layout" must be defined in callouts/scholia-callouts-framework.sty
% ============================================================================

% --- Per-call icon override mechanism ---------------------------------------
% A tcolorbox key `box icon=<filename>` lets the user override the default
% type-specific icon at the call site. The icon filename is stored in
% \scholia@callout@iconoverride and consumed by \scholia@callout@title.
% Empty value = no override (use the type's default icon).
\newcommand{\scholia@callout@iconoverride}{}
\tcbset{
  box icon/.store in=\scholia@callout@iconoverride,
  box icon/.default={},
}

% Resolve the icon to render: use override if non-empty, else type default.
% #1 = type-default icon filename
\newcommand{\scholia@callout@resolveicon}[1]{%
  \ifx\scholia@callout@iconoverride\@empty
    #1%
  \else
    \scholia@callout@iconoverride
  \fi
}

\newcommand{\scholia@callout@newtype}[1]{%
  % Create the box environment with two optional arguments:
  %   #1 = title text (default: empty)
  %   #2 = tcolorbox options (default: empty)
  \NewDocumentEnvironment{#1box}{O{} O{}}{%
    % Reset per-call icon override before each invocation
    \renewcommand{\scholia@callout@iconoverride}{}%
    \begin{tcolorbox}[%
      callout layout=scholia-#1,
      ##2,%
      title={\scholia@callout@title{\scholia@callout@resolveicon{\csname scholia@callout@icon@#1\endcsname}}{##1}},
    ]%
  }{\end{tcolorbox}}%
  % Create the mark (compact inline) environment
  \scholia@callout@newmark{#1mark}{scholia-#1}{\csname scholia@callout@icon@#1\endcsname}%
}


% ============================================================================
% HINT COMMAND FACTORY
% PURPOSE: Generate inline hint commands with colored label prefix
%
% Usage:
%   \scholia@hint@new{cmdname}{color}{labeltext}
%   Creates \<cmdname> command that displays: [label] hint text
%
% Example:
%   \scholia@hint@new{methodHint}{callout-method}{\scholia@str@callout@hint}
% ============================================================================

\newcommand{\scholia@hint@new}[3]{%
  \expandafter\newcommand\csname #1\endcsname[1]{%
    \par\smallskip\noindent
    \inlineframebox[#2]{#3}\;\textcolor{#2!60!black}{##1}%
    \par\smallskip
  }%
}


