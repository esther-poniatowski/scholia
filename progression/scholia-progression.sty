\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{\@currpath\@currname}[2026/03/20 v0.2.0 Beamer progression tools]

\tikzset{
  session-circle-base/.style={
    circle,
    minimum size=1.6em,
    inner sep=0pt,
    font=\bfseries\sffamily\small,
    thick,
  },
  session-circle-current/.style={
    session-circle-base,
    draw=black,
    text=black,
  },
  session-circle-other/.style={
    session-circle-base,
    draw=black!30,
    text=black!40,
  },
}

% -------------------------------------------------------------------------------------------------
% Variable: current session number (default value)
% -------------------------------------------------------------------------------------------------

\newcommand{\currentSession}{1}

% -------------------------------------------------------------------------------------------------
% Macro: a session in the progression
% -------------------------------------------------------------------------------------------------
% Usage: \sessionItem{<number>}{<long session title>}
% - Style is determined automatically:
%   - current number = black
%   - other sessions = grayed out
% -------------------------------------------------------------------------------------------------

\newcommand{\sessionItem}[2]{%
  \par
  \begingroup
    \def\sessionindex{#1}%
    \ifnum\sessionindex=\currentSession
      \def\sessioncircle{session-circle-current}%
      \def\sessiontextcolor{black}%
    \else
      \def\sessioncircle{session-circle-other}%
      \def\sessiontextcolor{black!50}%
    \fi
    %
    % Baseline aligned on the number's baseline
    \begin{tikzpicture}[baseline=(c.base)]
      % Circled number, anchored at (0,0), base defined by text
      \node[\sessioncircle] (c) at (0,0) {#1};
      % Text aligned on the same baseline, to the right of the circle
      \node[anchor=base west, font=\sffamily\small, text=\sessiontextcolor]
           (txt) at ([xshift=0.8em]c.base east) {#2};
    \end{tikzpicture}%
  \endgroup
}

% -------------------------------------------------------------------------------------------------
% Environment: session list
% -------------------------------------------------------------------------------------------------
% Usage:
%   \begin{sessionList}{<current session number>}
%     \sessionItem{1}{Title of the first session}
%     \sessionItem{2}{Title of the second session}
%     ...
%   \end{sessionList}
%
% Each \sessionItem creates a "paragraph" with small vertical spacing.
% -------------------------------------------------------------------------------------------------

\NewDocumentEnvironment{sessionList}{O{0.4em} m}{%
\renewcommand{\currentSession}{#2}%
\par
\begingroup
\setlength{\parskip}{#1}%
\setlength{\parindent}{0pt}%
}{%
\par
\endgroup
}


% --- Progressive outline ---
\RequirePackage{progression/scholia-outline}


